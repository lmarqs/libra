# Copied to .env by `mise run setup`. .env is gitignored — put real values there.

# Per-motor throttle band the balancer drives within, as 0..1 fractions mapped onto the ESC's
# 1000-2000 us range. Three knobs: MIN = hard floor (a motor never goes below it), MID = hover
# (where both motors rest at zero error), MAX = hard ceiling (never beyond). The PID's authority
# is derived to reach the farther edge from MID, so a motor can sweep the whole [MIN, MAX].
# Ships as a ZERO band [0.0, 0.0] with hover 0 → no thrust, no authority: the firmware is INERT
# until you set a real band for YOUR motor. Pick MIN/MAX from your spin-start/top-speed and set
# MID to your resting throttle (e.g. the reference 1404 4600KV/3S rig hovers ~0.085 in [0.080,
# 0.090], ~1080-1090 us; see docs/testing.md section 7). A nonzero MID lets both motors modulate
# down to correct. Widening the band raises thrust AND authority — the safety rules guard it.
LIBRA_THROTTLE_MIN=0.0
LIBRA_THROTTLE_MID=0.0
LIBRA_THROTTLE_MAX=0.0

# Tilt failsafe: past this many degrees the beam is considered lost and both
# motors cut until you re-enable.
LIBRA_TILT_LIMIT_DEG=45.0

# Pin map (I2C SDA/SCL, ESC1/2) is board-specific, so it lives as a per-board
# default in platformio.ini (literal -D flags per [env]), NOT here. Edit the env
# for your board (e.g. [env:esp32-c3-super-mini] or [env:esp32-wroom32]).

# Accelerometer tilt zero-offset (deg), subtracted from the measured angle so a
# physically level beam reads 0. Mounting-specific: hold the beam level, read the
# angle (LIBRA_LOG_LEVEL=4), and put that value here. 0 = no trim.
LIBRA_ANGLE_OFFSET_DEG=0.0

# WiFi SoftAP SSID for the tuning web UI (setpoint + PID gains). The web UI can never
# arm (arming is a hardware switch on the ESC), so the AP is safe left OPEN.
LIBRA_AP_SSID=libra

# Optional WPA2 password for that AP. Empty = open (default). WPA2 needs >= 8 chars; a
# shorter value is rejected at boot and the AP stays open. Set it to keep stray clients
# off the tuning UI.
LIBRA_AP_PASS=

# Debug verbosity, mapped to ESP32's CORE_DEBUG_LEVEL (0=none, 1=error, 2=warn,
# 3=info, 4=debug, 5=verbose). ALL serial output flows through the log_* API and is
# gated by this level: errors at 1, the boot banner + command replies + AP events at
# 3, the raw-IMU bring-up stream at 4. Below 3 hides the banner and command replies
# (probe/banner need >= 3). Leave at 3 for normal use; bump to 4 for IMU bring-up.
LIBRA_LOG_LEVEL=3

# Bench / calibration commands (set motors_enabled / set motors_speed / run / x). They drive
# the ESCs directly and bypass the kMaxThrottle cap + tilt failsafe, so they are PROPS-OFF only.
# 0 = compiled out (safe default, for props-on builds); 1 = enabled for bench work / calibration.
LIBRA_BENCH_ENABLED=0
