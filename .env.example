# Copied to .env by `mise run setup`. .env is gitignored — put real values there.

# Safety cap on per-motor throttle, as a 0..1 fraction. Injected as the
# LIBRA_THROTTLE_MAX build flag. 0.05 = 5% (a conservative bench-test ceiling);
# raise it deliberately once you trust your gains.
LIBRA_THROTTLE_MAX=0.05

# Tilt failsafe: past this many degrees the beam is considered lost and both
# motors cut until you re-enable.
LIBRA_TILT_LIMIT_DEG=45.0

# Pin map (GPIO numbers — verify against your board's silkscreen). GPIO2 is a
# strapping pin used for SDA; keep GPIO8/9 (strapping) and GPIO18/19 (USB) free.
LIBRA_I2C_SDA=2
LIBRA_I2C_SCL=3
LIBRA_ESC_PIN1=0
LIBRA_ESC_PIN2=1

# Accelerometer tilt zero-offset (deg), subtracted from the measured angle so a
# physically level beam reads 0. Mounting-specific: hold the beam level, read the
# angle (LIBRA_LOG_LEVEL=4), and put that value here. 0 = no trim.
LIBRA_ANGLE_OFFSET_DEG=0.0

# WiFi SoftAP credentials for the tuning web UI (setpoint + PID gains). WPA2
# requires the password to be 8-63 chars; a shorter one makes the AP fail to
# start. Arming stays serial-only — the web UI can never spin up the props.
LIBRA_AP_SSID=libra
LIBRA_AP_PASSWORD=balancebot

# Debug verbosity, mapped to ESP32's CORE_DEBUG_LEVEL (0=none, 1=error, 2=warn,
# 3=info, 4=debug, 5=verbose). Build with 4+ to stream raw IMU readings over
# serial (log_d) for axis/bias bring-up; leave at 3 for normal use.
LIBRA_LOG_LEVEL=3
